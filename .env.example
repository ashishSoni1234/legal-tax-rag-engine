# Legal & Tax RAG System — Environment Variables Template (Vercel Edition)
# Copy this file to .env and fill in your actual keys.

# ── LLM (Groq — Llama 3.3 70B) ──────────────────────────────────────────────
# Get a free key at https://console.groq.com/
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ── Google Gemini Embeddings ──────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Pinecone Vector Store ─────────────────────────────────────────────────────
# Get a free key at https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1   # e.g. us-east-1 (AWS region for serverless index)

# ── Hybrid Search Weights ─────────────────────────────────────────────────────
# vector + keyword should sum to 1.0
VECTOR_WEIGHT=0.6
KEYWORD_WEIGHT=0.4

# ── API Settings ──────────────────────────────────────────────────────────────
TOP_K=5
