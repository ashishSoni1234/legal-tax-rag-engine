# Legal & Tax RAG System — Environment Template
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── LLM (Groq — https://console.groq.com) ──────────────────────────────────
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ── Pinecone (https://app.pinecone.io) ─────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1

# ── Ollama Embeddings (local — https://ollama.ai) ──────────────────────────
# Install: ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# ── Elasticsearch BM25 (optional — docker-compose up -d) ───────────────────
ES_HOST=http://localhost:9200
ES_INDEX=legal_tax_rag

# ── Hybrid Search Weights (must sum to 1.0) ────────────────────────────────
VECTOR_WEIGHT=0.6
KEYWORD_WEIGHT=0.4
